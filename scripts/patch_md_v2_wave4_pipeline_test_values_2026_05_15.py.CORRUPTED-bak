                },
            },
            "breakdown_150D": {
                "tests": bd150_tests, "count": bd150_count, "total": 2,
                "rating": _pre_rating(bd150_count, 2), "qualifies": ind["breakdown_150D"],
                "test_values": {
                    "t1_price_below_150dma": _md_v2_pct_gap(price, ma150),
