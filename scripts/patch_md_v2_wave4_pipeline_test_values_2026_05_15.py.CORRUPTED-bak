#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
MD V2 — Wave 4 pipeline patcher: emit a `test_values` dict per V2 pattern.

For every md_v2 indicator / setup / deployment-test pattern emitted by
compute_master_dashboard_screens(), add a `test_values` dict alongside the
existing `tests` dict. Each entry is keyed by the SAME test key as `tests`,
and carries either:
  - the underlying numeric value used in the boolean comparison, OR
  - a short label string where the test is inherently binary (no continuous
    value behind it) — mirroring how Stage 3/4 already display such tests.

This is the data half of D-MD-V2 Wave 4 (the "Show test values" toggle).
The dashboard half (build_dashboard.py) reads rec.test_values[testKey].

Patcher discipline:
  - utf-8 IO; temp file beside the patcher (SCRIPT_DIR); atomic replace at END.
  - dry-run against the git-authoritative copy (`git show HEAD:<path>`).
  - idempotent: re-running is a no-op (MARKER guard).
  - per-anchor uniqueness asserted.
  - ast.parse compile-check before write.
  - MD5 self-report.
ASCII-only literals in this file.
"""

import ast
import hashlib
import os
import subprocess
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
TARGET = os.path.join(SCRIPT_DIR, "generate_master_data.py")
TMP = os.path.join(SCRIPT_DIR, ".patch_wave4_pipeline.tmp")
MARKER = "MD-V2-WAVE4-TEST-VALUES-MARKER"

# ---------------------------------------------------------------------------
# The helper block. Inserted immediately after the VCP helper's END marker.
# It defines _mdv2_test_values(...) which, given the locals already computed
# in compute_master_dashboard_screens at that point, returns the four
# test_values dicts (pre / post / setups / tests). Defined as a closure-free
# function taking explicit args so it is trivially reviewable and cannot
# silently capture the wrong variable.
# ---------------------------------------------------------------------------
HELPER_ANCHOR = "        # ── END MD-V2-SCREENS-S26-MARKER VCP helper ──\n"

# NB: built by string concatenation, not .format(), because the bodies contain
# literal { } braces. MARKER is interpolated via explicit replace().
HELPER_BLOCK = '''        # ── END MD-V2-SCREENS-S26-MARKER VCP helper ──

        # ── __MARKER__: per-pattern numeric test values (D-MD-V2 Wave 4) ──
        # For each md_v2 pattern, build a parallel dict keyed by the SAME test
        # keys as `tests`, carrying the underlying number where one exists or a
        # short label where the test is inherently binary. Computed here, in the
        # same pass, from the same locals that produced the booleans, so the
        # value and the boolean can never drift apart.
        def _md_v2_round(x, nd=4):
            try:
                if x is None:
                    return None
                return round(float(x), nd)
            except (TypeError, ValueError):
                return None

        def _md_v2_pct_gap(a, b):
            """(a - b) / b as a fraction, rounded; None if not computable."""
            try:
                if a is None or b is None or b == 0:
                    return None
                return round((float(a) - float(b)) / float(b), 4)
            except (TypeError, ValueError):
                return None
        # ── END __MARKER__ helper ──
'''.replace("__MARKER__", MARKER)

# ---------------------------------------------------------------------------
# Each entry: (anchor, replacement). anchor must be unique in the file.
# Every replacement adds exactly one `"test_values": {...}` key to an existing
# dict literal, leaving every other key byte-identical.
# ---------------------------------------------------------------------------

EDITS = []

# ----- PRE-INDICATORS (3 patterns) -----------------------------------------
# pulling_back_uptrend: 4 MA-direction booleans -> labels (no continuous value).
# basing: t1 -> max_pullback_ssh (fraction); t2 -> days_below_sh (int);
#         t3 -> price-vs-200d gap; t4 -> 200d MoM gap.
# collapsing: t1 -> price-vs-52wh gap; t2 -> recent_pullback (fraction).
EDITS.append((
    '''        md["pre_indicators"] = {
            "pulling_back_uptrend": {
                "tests": pb_tests, "count": pb_count, "total": 4,
                "rating": _pre_rating(pb_count, 4), "qualifies": ind["pulling_back_uptrend"],
            },
            "basing": {
                "tests": ba_tests, "count": ba_count, "total": 4,
                "rating": _pre_rating(ba_count, 4), "qualifies": ind["basing"],
            },
            "collapsing": {
                "tests": co_tests, "count": co_count, "total": 2,
                "rating": _pre_rating(co_count, 2), "qualifies": ind["collapsing"],
            },
        }''',
    '''        md["pre_indicators"] = {
            "pulling_back_uptrend": {
                "tests": pb_tests, "count": pb_count, "total": 4,
                "rating": _pre_rating(pb_count, 4), "qualifies": ind["pulling_back_uptrend"],
                "test_values": {
                    "t1_50d_rising": "rising" if pb_t1_50d_rising else "not rising",
                    "t2_150d_rising": "rising" if pb_t2_150d_rising else "not rising",
                    "t3_5d_rolling_over": "rolling over" if pb_t3_5d_rolling else "not rolling",
                    "t4_10d_rolling_over": "rolling over" if pb_t4_10d_rolling else "not rolling",
                },
            },
            "basing": {
                "tests": ba_tests, "count": ba_count, "total": 4,
                "rating": _pre_rating(ba_count, 4), "qualifies": ind["basing"],
                "test_values": {
                    "t1_price_pullback_ge15": _md_v2_round(max_pullback_ssh),
                    "t2_time_below_high_ge20d": days_below_sh,
                    "t3_price_above_200d": _md_v2_pct_gap(price, ma200),
                    "t4_200d_rising": _md_v2_pct_gap(ma200, ma200_prev),
                },
            },
            "collapsing": {
                "tests": co_tests, "count": co_count, "total": 2,
                "rating": _pre_rating(co_count, 2), "qualifies": ind["collapsing"],
                "test_values": {
                    "t1_price_le_70pct_52wh": _md_v2_pct_gap(price, h52),
                    "t2_pullback_ge20": _md_v2_round(recent_pullback),
                },
            },
        }''',
))

