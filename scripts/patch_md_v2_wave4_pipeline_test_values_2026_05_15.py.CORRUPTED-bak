# ---------------------------------------------------------------------------
# The VCP-values helper. _md_v2_vcp_values turns the 4 vcp test booleans +
# the contraction sequence into displayable values. The 4 VCP tests are
# inherently structural (strict monotonic sequences) so they have no single
# scalar; we surface the contraction count and a per-test label. This is
# defined inside the helper block so it is in scope at every call site.
# ---------------------------------------------------------------------------
VCP_HELPER = '''        def _md_v2_vcp_values(vt, contractions):
            n = len(contractions)
            return {
                "t1_narrowing_contractions": (
                    "narrowing" if vt.get("t1_narrowing_contractions") else "not narrowing"),
                "t2_sufficient_count": n,
                "t3_volume_declining": (
                    "declining" if vt.get("t3_volume_declining") else "not declining"),
                "t4_higher_lows": (
                    "higher lows" if vt.get("t4_higher_lows") else "not higher"),
            }
        # ── END __MARKER__ helper ──
'''.replace("__MARKER__", MARKER)


def main():
    # 1. Load the working-tree target (what will actually be patched on disk).
    if not os.path.exists(TARGET):
        sys.exit("ERROR: target not found: %s" % TARGET)
    with open(TARGET, "r", encoding="utf-8") as fh:
        disk_src = fh.read()

    # 2. Load the git-authoritative copy for the dry-run.
    try:
        git_src = subprocess.check_output(
            ["git", "show", "HEAD:scripts/generate_master_data.py"],
            cwd=SCRIPT_DIR, stderr=subprocess.STDOUT,
        ).decode("utf-8")
    except subprocess.CalledProcessError as exc:
        sys.exit("ERROR: could not read git HEAD copy: %s" % exc.output.decode("utf-8", "replace"))

    # 3. Idempotency guard.
    if MARKER in disk_src:
        print("MARKER already present in working-tree copy -- no-op. Patch already applied.")
        return
    if MARKER in git_src:
        print("MARKER already present in git HEAD copy -- no-op.")
        return

    def apply_all(src, label):
        out = src
        # Insert the helper block (HELPER_BLOCK includes the END-VCP anchor at
        # its head, so it REPLACES that anchor line, prepending nothing else).
        cnt = out.count(HELPER_ANCHOR)
        if cnt != 1:
            sys.exit("ERROR [%s]: helper anchor count = %d (expected 1)" % (label, cnt))
        # Build the combined helper: HELPER_BLOCK minus its trailing END line,
        # then VCP_HELPER (which carries its own END line).
        end_line = "        # ── END " + MARKER + " helper ──\n"
        helper_combined = HELPER_BLOCK.rsplit(end_line, 1)[0] + VCP_HELPER
        out = out.replace(HELPER_ANCHOR, helper_combined, 1)
        # Apply each pattern edit.
        for i, (anchor, repl) in enumerate(EDITS):
            c = out.count(anchor)
            if c != 1:
                sys.exit("ERROR [%s]: EDIT %d anchor count = %d (expected 1)" % (label, i, c))
            out = out.replace(anchor, repl, 1)
        return out

    # 4. Dry-run against git copy.
    _ = apply_all(git_src, "git-dry-run")
    print("Dry-run against git HEAD copy: all %d anchors matched uniquely." % (len(EDITS) + 1))

    # 5. Apply for real against the working-tree copy.
    patched = apply_all(disk_src, "working-tree")

    # 6. Compile-check.
    try:
        ast.parse(patched)
    except SyntaxError as exc:
        sys.exit("ERROR: patched source fails ast.parse: %s" % exc)
    print("ast.parse compile-check: OK")

    # 7. Atomic write via temp file beside the patcher.
    with open(TMP, "w", encoding="utf-8") as fh:
        fh.write(patched)
    os.replace(TMP, TARGET)

    new_md5 = hashlib.md5(patched.encode("utf-8")).hexdigest()
    print("WROTE %s" % TARGET)
    print("  new size : %d bytes" % len(patched.encode("utf-8")))
    print("