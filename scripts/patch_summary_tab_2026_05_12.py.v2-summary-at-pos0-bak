r"""
Patcher: SUMMARY tab V1 (12-May-26 Session 19, v2)

Idempotent. Pre-write backup. py_compile verification. FUSE truncation guard.
Operates on BYTES (not text) to preserve Windows CRLF line endings and Unicode
em-dashes (U+2014) used in the source.

Injects 6 changes into scripts/build_dashboard.py:
  1. TABS list - prepends SUMMARY entry as first element (TAB 0)
  2. IMPLEMENTED_TABS - adds "summary"
  3. currentTab default - flips "changes" -> "summary"
  4. renderTab dispatch - adds summary branch as first conditional
  5. JS module - injects _summary_tab_module.js content before renderTab function
  6. Startup call - adds deriveMasterRatings() after precomputeSsemRatings()

MUST run Windows-side. The FUSE truncation guard will refuse to run on the
Cowork mount because read() returns a truncated view there.

Run:
  cd C:\Users\richb\Documents\COWORK\master-dashboard
  python scripts\patch_summary_tab_2026_05_12.py
"""
import sys
import os
import shutil
import py_compile
from pathlib import Path
from datetime import datetime

SCRIPT_DIR = Path(__file__).parent.resolve()
DASH_PY = SCRIPT_DIR / "build_dashboard.py"
MODULE_JS = SCRIPT_DIR / "_summary_tab_module.js"
MARKER_BYTES = b"SUMMARY-TAB-MARKER"

EM = "—".encode("utf-8")  # em-dash UTF-8 bytes
CRLF = b"\r\n"

ANCHOR_TABS = (
    b'TABS = [' + CRLF
    + b'    # STAGE-REFACTOR-V3-MARKER ' + EM + b' 8 filter tabs grouped by Minervini-style stage' + CRLF
    + b'    # Stage 1 ' + EM + b' Basing/bottoming' + CRLF
    + b'    {"id": "bp",        "label": "Basing Plateau",   "accent": "#276749", "stage": 1},'
)

REPLACE_TABS = (
    b'TABS = [' + CRLF
    + b'    # SUMMARY-TAB-MARKER ' + EM + b' synoptic view, default landing tab (D-MD-UI-38)' + CRLF
    + b'    {"id": "summary",   "label": "SUMMARY",          "accent": "#4a5568"},' + CRLF
    + b'    # STAGE-REFACTOR-V3-MARKER ' + EM + b' 8 filter tabs grouped by Minervini-style stage' + CRLF
    + b'    # Stage 1 ' + EM + b' Basing/bottoming' + CRLF
    + b'    {"id": "bp",        "label": "Basing Plateau",   "accent": "#276749", "stage": 1},'
)

ANCHOR_IMPL = (
    b'IMPLEMENTED_TABS = [' + CRLF
    + b'    "mm99", "bp", "pb", "utr", "vcp", "tech", "combos", "changes", "positions",' + CRLF
    + b'    "ssem", "val",' + CRLF
    + b']'
)

REPLACE_IMPL = (
    b'IMPLEMENTED_TABS = [' + CRLF
    + b'    "summary",' + CRLF
    + b'    "mm99", "bp", "pb", "utr", "vcp", "tech", "combos", "changes", "positions",' + CRLF
    + b'    "ssem", "val",' + CRLF
    + b']'
)

ANCHOR_CURRENTTAB = b'var currentTab="changes",currentSort={col:"chg_qual_count",dir:"desc"}; /* Q1Q2-CLEANUP-V1 */'
REPLACE_CURRENTTAB = b'var currentTab="summary",currentSort={col:"chg_qual_count",dir:"desc"}; /* SUMMARY-TAB-DEFAULT */'

ANCHOR_RENDERTAB = (
    b'function renderTab(id){' + CRLF
    + b'  try{' + CRLF
    + b'  if(id==="mm99")renderMM99();'
)

REPLACE_RENDERTAB = (
    b'function renderTab(id){' + CRLF
    + b'  try{' + CRLF
    + b'  if(id==="summary")renderSummary();' + CRLF
    + b'  else if(id==="mm99")renderMM99();'
)

ANCHOR_PRECOMPUTE = (
    b'precomputeSsemRatings();' + CRLF
    + CRLF
    + b'renderTab("mm99");'
)

REPLACE_PRECOMPUTE = (
    b'precomputeSsemRatings();' + CRLF
    + b'deriveMasterRatings();  /* SUMMARY-TAB-MARKER */' + CRLF
    + CRLF
    + b'renderTab("mm99");'
)

ANCHOR_MODULE_INJECT = (
    b'document.getElementById("tab-changes").innerHTML=h;' + CRLF
    + b'}' + CRLF
    + CRLF
    + b'function renderTab(id){'
)


def fail(msg):
    print(f"ERROR: {msg}")
    sys.exit(1)


def main():
    if not DASH_PY.exists():
        fail(f"build_dashboard.py not found at {DASH_PY}")
    if not MODULE_JS.exists():
        fail(f"_summary_tab_module.js not found at {MODULE_JS}")

    # FUSE truncation guard: open + read entire file via low-level os.read
    # (which on FUSE returns the full file even when text-mode read truncates).
    # Then compare against os.path.getsize.
    on_disk_size = os.path.getsize(DASH_PY)

    # Read full file as bytes (not text)
    with open(DASH_PY, "rb") as f:
        orig = f.read()
    orig_size = len(orig)

    if on_disk_size != orig_size:
        fail(
            f"FUSE TRUNCATION DETECTED. os.path.getsize={on_disk_size} but read={orig_size}. "
            f"Run Windows-side, NOT via Cowork mount."
        )

    EXPECTED_BASELINE_SIZE = 285691
    if orig_size < EXPECTED_BASELINE_SIZE - 100:
        fail(f"Size {orig_size} below baseline {EXPECTED_BASELINE_SIZE}. Aborting.")

    if MARKER_BYTES in orig:
        print(f"Idempotent no-op: SUMMARY-TAB-MARKER already present ({orig_size} bytes).")
        return 0

    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    bak = DASH_PY.with_suffix(f".py.bak-pre-summary-tab-{ts}")
    shutil.copy2(DASH_PY, bak)
    print(f"Backup: {bak.name} ({orig_size:,} bytes)")

    # Read module JS as bytes
    with open(MODULE_JS, "rb") as f:
        module_js = f.read()
    module_size = len(module_js)
    print(f"Module JS: {module_size:,} bytes")

    # Ensure module JS uses CRLF line endings to match host file convention
    if b"\r\n" not in module_js[:2000]:
        # Convert LF to CRLF
        module_js = module_js.replace(b"\r\n", b"\n").replace(b"\n", b"\r\n")
        print(f"  Note: normalized module_js to CRLF ({len(module_js)} bytes)")

    patches = [
        ("TABS list",          ANCHOR_TABS,        REPLACE_TABS),
        ("IMPLEMENTED_TABS",   ANCHOR_IMPL,        REPLACE_IMPL),
        ("currentTab default", ANCHOR_CURRENTTAB,  REPLACE_CURRENTTAB),
        ("renderTab dispatch", ANCHOR_RENDERTAB,   REPLACE_RENDERTAB),
        ("Startup call",       ANCHOR_PRECOMPUTE,  REPLACE_PRECOMPUTE),
    ]

    new = orig
    for name, anchor, replace in patches:
        c = new.count(anchor)
        if c == 0:
            fail(f"Anchor not found: '{name}' (len={len(anchor)}). Aborting.")
        if c > 1:
            fail(f"Anchor matched {c}x: '{name}'. Aborting.")
        new = new.replace(anchor, replace)
        print(f"  Applied: {name}")

    mc = new.count(ANCHOR_MODULE_INJECT)
    if mc == 0:
        fail("Module injection anchor not found.")
    if mc > 1:
        fail(f"Module injection anchor matched {mc}x.")

    module_replacement = (
        b'document.getElementById("tab-changes").innerHTML=h;' + CRLF
        + b'}' + CRLF
        + CRLF
        + module_js + CRLF
        + b'function renderTab(id){'
    )
    new = new.replace(ANCHOR_MODULE_INJECT, module_replacement)
    print("  Applied: Module injection")

    new_size = len(new)
    delta = new_size - orig_size
    print(f"\nSize: {orig_size:,} -> {new_size:,} (+{delta:,} bytes)")

    expected_min = module_size + 200
    expected_max = module_size + 2000
    if delta < expected_min or delta > expected_max:
        fail(f"Delta {delta} outside [{expected_min}, {expected_max}].")

    # Write as bytes (preserves CRLF)
    with open(DASH_PY, "wb") as f:
        f.write(new)

    # py_compile verification
    try:
        py_compile.compile(str(DASH_PY), doraise=True)
        print("py_compile: OK")
    except py_compile.PyCompileError as e:
        shutil.copy2(bak, DASH_PY)
        fail(f"py_compile FAILED. Backup restored.\n{e}")

    # Verify marker present, sizes match
    with open(DASH_PY, "rb") as f:
        final = f.read()
    if MARKER_BYTES not in final:
        shutil.copy2(bak, DASH_PY)
        fail("Marker missing after write. Backup restored.")

    final_disk = os.path.getsize(DASH_PY)
    if final_disk != len(final):
        shutil.copy2(bak, DASH_PY)
        fail(f"Post-write truncation (disk={final_disk}, read={len(final)}). Restored.")

    print(f"\nSUCCESS. {DASH_PY.name} now {final_disk:,} bytes.")
    print(f"Next: python scripts\\build_dashboard.py")
    print(f"Then push via GitHub Desktop.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
